# ═══════════════════════════════════════════════════════════════════════════════
# 🔐 ENVIRONMENT CONFIGURATION — AI_CONTENT_GTO_ENGINE
# ═══════════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════════════════════════════════

# ═══════════════════════════════════════════════════════════════════════════════
# 🗄️ SUPABASE CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════════

# Supabase Project URL (from Supabase Dashboard > Settings > API)
VITE_SUPABASE_URL=https://your-project-id.supabase.co
REACT_APP_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase Anonymous Key (public, safe for client-side)
VITE_SUPABASE_ANON_KEY=your-anon-key-here
REACT_APP_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase Service Role Key (secret, server-side only!)
SUPABASE_SERVICE_KEY=your-service-key-here

# ═══════════════════════════════════════════════════════════════════════════════
# 🔐 SECURITY & CRYPTOGRAPHY
# ═══════════════════════════════════════════════════════════════════════════════

# Secret key for Mastery Token HMAC signing (32+ characters recommended)
MASTERY_SEAL_SECRET=your-secret-key-for-mastery-tokens-min-32-chars

# ═══════════════════════════════════════════════════════════════════════════════
# 🎮 APPLICATION SETTINGS
# ═══════════════════════════════════════════════════════════════════════════════

# Node environment
NODE_ENV=development

# Application port (for server-side operations)
PORT=3000

# ═══════════════════════════════════════════════════════════════════════════════
# 📊 FEATURE FLAGS
# ═══════════════════════════════════════════════════════════════════════════════

# Enable debug logging
VITE_DEBUG_MODE=false

# Enable real-time sync
VITE_ENABLE_REALTIME=true

# Enable analytics tracking
VITE_ENABLE_ANALYTICS=false

# ═══════════════════════════════════════════════════════════════════════════════
# ⚠️ IMPORTANT NOTES
# ═══════════════════════════════════════════════════════════════════════════════
# 1. NEVER commit .env to version control
# 2. Service keys should ONLY be used server-side
# 3. Rotate MASTERY_SEAL_SECRET if compromised
# 4. Use separate Supabase projects for dev/staging/prod
# ═══════════════════════════════════════════════════════════════════════════════
